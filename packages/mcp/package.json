{
  "name": "dc-cli-mcp",
  "version": "0.0.0",
  "description": "调用done-coding命令行的mcp服务",
  "private": false,
  "module": "es/index.mjs",
  "types": "types/index.d.ts",
  "type": "module",
  "bin": {
    "dc-cli-mcp": "./es/index.mjs"
  },
  "exports": {
    ".": {
      "import": "./es/index.mjs",
      "types": "./types/index.d.ts"
    }
  },
  "files": [
    "es",
    "lib",
    "types"
  ],
  "scripts": {
    "clean": "rimraf es lib dist types coverage",
    "dev": "vite build -w",
    "predev": "pnpm run clean && dc-inject",
    "build": "vite build",
    "prebuild": "pnpm run clean && dc-inject",
    "prepack": "pnpm build",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/done-coding/done-coding-cli.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "JustSoSu",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@done-coding/cli-inject": "workspace:0.5.20",
    "@types/node": "^18.0.0",
    "@vitest/coverage-istanbul": "^1.1.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^5.0.10",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@done-coding/cli-component": "workspace:0.4.9",
    "@done-coding/cli-utils": "workspace:0.8.1",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "create-done-coding": "workspace:0.11.22",
    "zod": "^4.3.5"
  }
}