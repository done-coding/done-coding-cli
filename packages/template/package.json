{
  "name": "@done-coding/cli-template",
  "version": "0.9.0",
  "description": "预编译命令行工具",
  "private": false,
  "module": "es/index.mjs",
  "type": "module",
  "types": "types/index.d.ts",
  "bin": {
    "dc-template": "es/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./es/index.mjs",
      "types": "./types/index.d.ts"
    }
  },
  "files": [
    "es",
    "lib",
    "types"
  ],
  "scripts": {
    "dev": "vite build -w -m hotBuild",
    "build": "vite build",
    "prepack": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/done-coding/done-coding-cli.git",
    "directory": "packages/template"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "JustSoSu",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@done-coding/cli-inject": "workspace:0.6.0",
    "@types/lodash.assign": "^4.2.9",
    "@types/lodash.template": "^4.5.3",
    "@types/node": "^18.0.0",
    "@types/yargs": "^17.0.28",
    "typescript": "^5.8.3",
    "vite": "^4.4.11",
    "vite-plugin-dts": "^3.6.0"
  },
  "dependencies": {
    "@done-coding/cli-utils": "workspace:0.9.0",
    "lodash.assign": "^4.2.0",
    "lodash.template": "^4.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
