{
  "name": "@done-coding/cli-git",
  "version": "0.5.1-alpha.0",
  "description": "git跨平台操作命令行工具",
  "private": false,
  "module": "es/index.mjs",
  "type": "module",
  "types": "types/index.d.ts",
  "bin": {
    "dc-git": "es/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./es/index.mjs"
    },
    "./helpers": {
      "import": "./es/helpers.mjs",
      "types": "./types/helpers.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "helpers": [
        "./types/helpers.d.ts"
      ]
    }
  },
  "files": [
    "es",
    "lib",
    "types"
  ],
  "scripts": {
    "clean": "rimraf es lib types",
    "predev": "pnpm run clean",
    "dev": "vite build --watch",
    "prebuild": "pnpm run clean",
    "build": "vite build",
    "prepack": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/justsosu/done-coding-cli.git",
    "directory": "packages/git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "JustSoSu",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@done-coding/cli-inject": "workspace:^",
    "@types/node": "^18.0.0",
    "@types/yargs": "^17.0.28",
    "rimraf": "^6.0.1",
    "typescript": "^5.2.2",
    "vite": "^4.4.11",
    "vite-plugin-dts": "^3.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@done-coding/cli-utils": "workspace:^",
    "@done-coding/request-axios": "^1.1.1",
    "axios": "^1.8.4"
  }
}
