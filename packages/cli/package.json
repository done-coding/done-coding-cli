{
  "name": "@done-coding/cli",
  "version": "0.15.21-alpha.0",
  "description": "done-coding命令行工具",
  "private": false,
  "module": "es/cli.mjs",
  "type": "module",
  "types": "types/cli.d.ts",
  "bin": {
    "DC": "es/cli.mjs",
    "dc-cli": "es/dc-cli.mjs",
    "done-coding": "es/done-coding.mjs"
  },
  "exports": {
    ".": {
      "import": "./es/index.mjs",
      "types": "./types/index.d.ts"
    }
  },
  "files": [
    "es",
    "lib",
    "types",
    "scripts/postinstall.mjs"
  ],
  "scripts": {
    "moreCli": "node ./scripts/more-cli.mjs",
    "dev": "vite build -w -m hotBuild",
    "build": "vite build && pnpm run moreCli",
    "postinstall": "node scripts/postinstall.mjs",
    "prepack": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/done-coding/done-coding-cli.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "JustSoSu",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^18.0.0",
    "typescript": "^5.8.3",
    "vite": "^4.4.11",
    "vite-plugin-dts": "^3.6.0"
  },
  "dependencies": {
    "@done-coding/cli-component": "workspace:0.4.11-alpha.0",
    "@done-coding/cli-config": "workspace:0.1.14-alpha.0",
    "@done-coding/cli-extract": "workspace:0.1.22-alpha.0",
    "@done-coding/cli-git": "workspace:0.6.14-alpha.0",
    "@done-coding/cli-inject": "workspace:0.5.22-alpha.0",
    "@done-coding/cli-publish": "workspace:0.7.15-alpha.0",
    "@done-coding/cli-template": "workspace:0.8.9-alpha.0",
    "@done-coding/cli-utils": "workspace:0.8.3-alpha.0",
    "create-done-coding": "workspace:0.11.24-alpha.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
