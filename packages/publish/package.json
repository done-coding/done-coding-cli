{
  "name": "@done-coding/cli-publish",
  "version": "0.7.16",
  "description": "项目发布命令行工具",
  "private": false,
  "module": "es/index.mjs",
  "type": "module",
  "types": "types/index.d.ts",
  "bin": {
    "dc-publish": "es/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./es/index.mjs",
      "types": "./types/index.d.ts"
    }
  },
  "files": [
    "es",
    "lib",
    "types"
  ],
  "scripts": {
    "dev": "vite build -w -m hotBuild",
    "build": "vite build",
    "prepack": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/done-coding/done-coding-cli.git",
    "directory": "packages/publish"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "JustSoSu",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@done-coding/cli-inject": "workspace:0.5.23",
    "@types/node": "^18.0.0",
    "@types/semver": "^7.5.3",
    "@types/yargs": "^17.0.28",
    "typescript": "^5.8.3",
    "vite": "^4.4.11",
    "vite-plugin-dts": "^3.6.0"
  },
  "dependencies": {
    "@done-coding/cli-utils": "workspace:0.8.4",
    "semver": "^7.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
