{
  "name": "@done-coding/cli-publish",
  "version": "0.3.6",
  "description": "项目发布命令行工具",
  "private": false,
  "module": "es/index.mjs",
  "type": "module",
  "types": "types/index.d.ts",
  "bin": {
    "dc-publish": "es/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./es/index.mjs"
    }
  },
  "files": [
    "es",
    "lib",
    "types",
    "gif"
  ],
  "scripts": {
    "clean": "rimraf es lib types",
    "predev": "pnpm run clean",
    "dev": "vite build --watch",
    "prebuild": "pnpm run clean",
    "build": "vite build",
    "prepack": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/justsosu/done-coding-cli.git",
    "directory": "packages/publish"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "JustSoSu",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@done-coding/cli-inject": "workspace:^",
    "@types/node": "^18.0.0",
    "@types/pinyin": "^2.10.0",
    "@types/prompts": "^2.4.6",
    "@types/semver": "^7.5.3",
    "@types/yargs": "^17.0.28",
    "rimraf": "^6.0.1",
    "typescript": "^5.2.2",
    "vite": "^4.4.11",
    "vite-plugin-dts": "^3.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "pinyin": "^2.11.2",
    "prompts": "^2.4.2",
    "semver": "^7.5.4",
    "yargs": "^17.7.2"
  }
}
