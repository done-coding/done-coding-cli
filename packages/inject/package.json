{
  "name": "@done-coding/cli-inject",
  "version": "0.4.6-alpha.0",
  "description": "信息注入命令行工具",
  "private": false,
  "module": "es/index.mjs",
  "type": "module",
  "types": "types/index.d.ts",
  "bin": {
    "dc-inject": "es/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./es/index.mjs"
    },
    "./use": {
      "import": "./es/use.mjs",
      "types": "./types/use.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "use": [
        "./types/use.d.ts"
      ]
    }
  },
  "files": [
    "es",
    "lib",
    "types"
  ],
  "scripts": {
    "clean": "rimraf es lib types",
    "predev": "pnpm run clean",
    "dev": "vite build --watch",
    "prebuild": "pnpm run clean",
    "build": "vite build",
    "prepack": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/justsosu/done-coding-cli.git",
    "directory": "packages/inject"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "JustSoSu",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@types/lodash.get": "^4.4.9",
    "@types/lodash.set": "^4.3.9",
    "@types/node": "^18.0.0",
    "@types/prompts": "^2.4.6",
    "@types/yargs": "^17.0.28",
    "rimraf": "^6.0.1",
    "typescript": "^5.2.2",
    "vite": "^4.4.11",
    "vite-plugin-dts": "^3.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "lodash.get": "^4.4.2",
    "lodash.set": "^4.3.2",
    "prompts": "^2.4.2",
    "yargs": "^17.7.2"
  }
}
