{
  "name": "@done-coding/mcp-utils",
  "version": "0.0.2-alpha.2",
  "description": "mcp utils",
  "private": false,
  "module": "es/index.mjs",
  "types": "types/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./es/index.mjs",
      "types": "./types/index.d.ts"
    },
    "./server": {
      "import": "./es/server.mjs",
      "types": "./types/server.d.ts"
    },
    "./client": {
      "import": "./es/client.mjs",
      "types": "./types/client.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "server": [
        "./types/server.d.ts"
      ],
      "client": [
        "./types/client.d.ts"
      ]
    }
  },
  "files": [
    "es",
    "lib",
    "types"
  ],
  "scripts": {
    "dev": "vite build -w -m hotBuild",
    "build": "vite build",
    "prepack": "pnpm build",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/done-coding/done-coding-cli.git",
    "directory": "packages/mcp-utils"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "JustSoSu",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.8.3",
    "vite": "^5.0.10",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "zod": "^4.3.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
